{
	"$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
	"version": 3,
	"console_title_template": "{{.UserName}} on {{.HostName}}",
	"blocks": [
		{
			"type": "prompt",
			"alignment": "left",
			"segments": [
				{
					"type": "os",
					"style": "powerline",
					"template": " {{ .Icon }} ",
					"background_templates": [
						"{{ if eq .OS \"windows\" }}#37699e{{ else if eq .OS \"darwin\" }}#FFF{{ else }}#111{{ end }}"
					],
					"foreground_templates": [
						"{{ if eq .OS \"windows\" }}#FFF{{ else if eq .OS \"darwin\" }}#111{{ else }}#FFF{{ end }}"
					]
				},
				{
					"type": "bun",
					"style": "powerline",
					"powerline_symbol": "\ue0b0",
					"foreground": "#e5e7eb",
					"background": "#111111",
					"display_mode": "files",
					"options": {
						"fetch_version": true,
						"files": [
							"bun.lock"
						]
					},
					"template": " \ue22e {{ .Major }}.{{ .Minor }}.{{ .Patch }} "
				},
				{
					"type": "node",
					"style": "powerline",
					"powerline_symbol": "\ue0b0",
					"background": "#2c682c",
					"foreground": "#ffffff",
					"display_mode": "files",
					"options": {
						"fetch_version": true,
						"files": [
							"package.json"
						]
					},
					"template": "{{ if not (glob \"bun.lock\") }} \ue718 {{ .Major }} {{ end }}"
				},
				{
					"type": "svelte",
					"display_mode": "always",
					"options": {
						"fetch_version": true
					},
					"style": "powerline",
					"foreground": "#FFF",
					"background": "#fc3a15",
					"template": "  {{ .Major }} "
				},
				{
					"type": "dotnet",
					"style": "powerline",
					"foreground": "#000000",
					"background": "#00ffff",
					"template": "  {{ .Major }}.{{ .Minor }}  "
				},
				{
					"type": "path",
					"style": "powerline",
					"powerline_symbol": "\ue0b0",
					"background": "#FFFFFF",
					"foreground": "#b40000",
					"options": {
						"folder_separator_icon": " \ue0b1 ",
						"home_icon": "~",
						"style": "folder"
					},
					"template": " \uea83 {{ .Path }}",
					"trailing_diamond": "\ue0b0"
				},
				{
					"type": "git",
					"style": "powerline",
					"leading_diamond": "\ue0b6",
					"powerline_symbol": "\ue0b0",
					"trailing_diamond": "\ue0b4",
					"foreground": "#111111",
					"background": "#ffffff",
					"background_templates": [
						"{{ if or (.Working.Changed) (.Staging.Changed) }}#FF9248{{ end }}",
						"{{ if and (gt .Ahead 0) (gt .Behind 0) }}#ff4500{{ end }}",
						"{{ if gt .Ahead 0 }}#B388FF{{ end }}",
						"{{ if gt .Behind 0 }}#B388FF{{ end }}"
					],
					"options": {
						"branch_max_length": 25,
						"fetch_stash_count": true,
						"fetch_status": true,
						"fetch_upstream_icon": true
					},
					"template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} "
				},
				{
					"type": "root",
					"style": "powerline",
					"powerline_symbol": "\ue0b0",
					"background": "#ffffff",
					"foreground": "#111111",
					"template": " \uf0ad "
				}
			]
		}
	]
}
